{
  "name": "audiolayer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out',{recursive:true,force:true})\"",
    "test": "node scripts/test.mjs test",
    "coverage": "node scripts/test.mjs coverage",
    "build": "node scripts/build.mjs",
    "run:client": "gradlew runClient",
    "run:server": "gradlew runServer",
    "run:data": "gradlew runData",
    "run:gametest": "gradlew runGameTestServer",
    "compat:etched": "gradlew runCompatEtched",
    "prepare:kubejs": "gradlew --quiet dependencies --configuration compileClasspath 2>&1 | grep kubejs || echo 'KubeJS resolved'"
  }
}
